# Copy to `.streamlit/secrets.toml` for local runs (never commit secrets).
# On Streamlit Community Cloud: Manage app → Secrets (same keys).
#
# Default Hub repo adeelumar17/cyclegan is not anonymous-readable — use HF_TOKEN or another option below.

# HF_TOKEN = "hf_..."          # read token: https://huggingface.co/settings/tokens
# HF_REPO_ID = "user/repo"     # your own public Hub repo with checkpoints/…/*.pth

# Optional: bypass Hugging Face — direct HTTPS links to the raw .pth files (set BOTH):
# CKPT_G_AB_URL = "https://…/G_AB_epoch35.pth"
# CKPT_G_BA_URL = "https://…/G_BA_epoch35.pth"
