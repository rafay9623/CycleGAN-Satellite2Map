# Copy to `.streamlit/secrets.toml` for local runs (never commit secrets).
# On Streamlit Community Cloud: App → Settings → Secrets (same keys).

# HF_TOKEN = "hf_..."          # read token if the Hub repo is private or gated
# HF_REPO_ID = "user/repo"     # optional; default is adeelumar17/cyclegan

# Optional: bypass Hugging Face — direct HTTPS links to the raw .pth files (set BOTH):
# CKPT_G_AB_URL = "https://…/G_AB_epoch35.pth"
# CKPT_G_BA_URL = "https://…/G_BA_epoch35.pth"
